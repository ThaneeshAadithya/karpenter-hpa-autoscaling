{
  "description": "Karpenter + HPA autoscaling overview — node scale events, pod counts, p99 latency",
  "panels": [
    {
      "id": 1, "title": "Active Nodes by NodePool", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "karpenter:nodes_by_pool:count", "legendFormat": "{{ nodepool }}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2, "title": "Pending Pods", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cluster:pending_pods:count", "legendFormat": "Pending", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"},
        "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}}
    },
    {
      "id": 3, "title": "Spot Node Ratio", "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "cluster:spot_node_ratio:ratio", "legendFormat": "Spot %", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "id": 4, "title": "Total Running Pods", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(kube_pod_status_phase{phase='Running'})", "legendFormat": "Running", "refId": "A"}]
    },
    {
      "id": 5, "title": "Node Count Over Time (by NodePool)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "karpenter:nodes_by_pool:count", "legendFormat": "{{ nodepool }}", "refId": "A"},
        {"expr": "cluster:pending_pods:count", "legendFormat": "Pending pods", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 6, "title": "HPA Replica Decisions", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace='$namespace'}", "legendFormat": "{{ horizontalpodautoscaler }} current", "refId": "A"},
        {"expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace='$namespace'}", "legendFormat": "{{ horizontalpodautoscaler }} max", "refId": "B"},
        {"expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace='$namespace'}", "legendFormat": "{{ horizontalpodautoscaler }} min", "refId": "C"}
      ]
    },
    {
      "id": 7, "title": "p99 Latency During Scaling", "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le, service) (rate(http_request_duration_seconds_bucket{namespace='$namespace'}[2m])))", "legendFormat": "{{ service }} p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket{namespace='$namespace'}[2m])))", "legendFormat": "{{ service }} p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_request_duration_seconds_bucket{namespace='$namespace'}[2m])))", "legendFormat": "{{ service }} p99", "refId": "C"},
        {"expr": "vector(0.5)", "legendFormat": "SLO target (500ms)", "refId": "D"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "schemaVersion": 38,
  "tags": ["karpenter", "hpa", "autoscaling", "latency"],
  "templating": {
    "list": [
      {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"},
       "query": "label_values(kube_pod_info, namespace)", "refresh": 2}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "title": "Autoscaling Overview — Karpenter + HPA",
  "uid": "autoscaling-overview",
  "version": 1
}
